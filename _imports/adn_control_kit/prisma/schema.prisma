enum LedgerEntryType {
  tap_reward
  passive_income
  mission_reward
  referral_reward
  daily_reward
  purchase_spend
  premium_purchase
  admin_adjustment
  reversal
  payout_lock
  payout_release
}

enum BalanceBucket {
  coins
  adn
  eligible_reward
  locked_reward
}

enum DeviceTrustStatus {
  trusted
  unknown
  risky
  blocked
}

enum IdempotencyStatus {
  processing
  completed
  failed
}

model User {
  id                   String   @id @default(cuid())
  telegramId           String   @unique
  username             String?
  isAdmin              Boolean  @default(false)
  isBanned             Boolean  @default(false)
  suspiciousScore      Int      @default(0)
  fraudLockedUntil     DateTime?
  deviceFingerprint    String?
  ipHash               String?
  countryCode          String?
  coins                Int      @default(0)
  adnBalance           Int      @default(0)
  eligibleRewardBalance Int     @default(0)
  lockedRewardBalance  Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  ledgerEntries        WalletLedgerEntry[]
  devices              UserDevice[]
  reviews              FraudReviewCase[]
  idempotencyKeys      IdempotencyKey[]
}

model WalletLedgerEntry {
  id            String          @id @default(cuid())
  userId        String
  entryType     LedgerEntryType
  bucket        BalanceBucket
  amount        Int
  balanceBefore Int
  balanceAfter  Int
  reason        String
  refType       String?
  refId         String?
  metadataJson  String?
  createdAt     DateTime        @default(now())

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([entryType, createdAt])
}

model UserDevice {
  id                String            @id @default(cuid())
  userId            String
  fingerprint       String
  platform          String?
  appVersion        String?
  firstSeenAt       DateTime          @default(now())
  lastSeenAt        DateTime          @default(now())
  totalSessions     Int               @default(1)
  trustStatus       DeviceTrustStatus @default(unknown)
  riskFlagsJson     String?

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([fingerprint])
  @@index([trustStatus])
}

model FraudReviewCase {
  id              String   @id @default(cuid())
  userId          String
  status          String   @default("open")
  severity        String   @default("medium")
  title           String
  summary         String
  riskSignalsJson String?
  openedBy        String?
  resolvedBy      String?
  resolutionNote  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model IdempotencyKey {
  id            String             @id @default(cuid())
  userId        String
  scope         String
  idempotencyKey String
  requestHash   String
  status        IdempotencyStatus  @default(processing)
  responseJson  String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scope, idempotencyKey])
  @@index([status, createdAt])
}
